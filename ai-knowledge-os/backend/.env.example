# AI Knowledge Operating System - Backend Configuration Example
# Copy this file to .env and fill in your details

# Gemini API key for LLM and advanced reasoning tasks
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MAIN_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_FALLBACK_MODEL_1=google/gemma-4-31b-it:free
LLM_FALLBACK_MODEL_2=openrouter/free

# Local vector database storage path
QDRANT_PATH=data/qdrant

# Ingestion config
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# File Upload configuration
UPLOAD_DIR=data/uploads

# Server configuration
HOST=127.0.0.1
PORT=8000
